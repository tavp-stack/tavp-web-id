APP_NAME=TAVP
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tavp.web.id
APP_LOCALE=id
APP_KEY=

# Database (MariaDB)
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tavp
DB_USERNAME=tavp
DB_PASSWORD=

# CMS
CMS_STORAGE=database
CMS_THEME=tavp

# Admin panel — comma-separated allow-list of e-mails that may sign in
CMS_ADMIN_EMAILS=you@example.com
CMS_OTP_TTL=10

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@tavp.web.id
