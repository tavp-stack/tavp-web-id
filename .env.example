APP_NAME=TAVP
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tavp.web.id
APP_LOCALE=id
APP_KEY=

# CMS storage: flatfile | database
CMS_STORAGE=flatfile
CMS_THEME=tavp

# Admin panel — comma-separated allow-list of e-mails that may sign in
CMS_ADMIN_EMAILS=you@example.com
CMS_OTP_TTL=10

# Mail (dev: Lando Mailpit). Host is the Lando service name; port is internal.
# Mailpit web UI is exposed to the host on http://localhost:8026
MAIL_DRIVER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@tavp.web.id
