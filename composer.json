{
    "name": "tavp/web-id",
    "description": "tavp.web.id — the official TAVP website, built on TAVP CMS (dogfooding).",
    "type": "project",
    "license": "MIT",
    "repositories": [
        { "type": "path", "url": "../tavp-stack/tavp-cms", "options": { "symlink": false } },
        { "type": "path", "url": "../tavp-stack/tavp-cli", "options": { "symlink": false } }
    ],
    "require": {
        "php": ">=8.3",
        "tavp/core": "^1.1",
        "tavp/cms": "@dev",
        "tavp/tavpid": "^1.0",
        "tavp/tavphub": "^1.1"
    },
    "require-dev": {
        "tavp/cli": "@dev"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {}
    }
}
